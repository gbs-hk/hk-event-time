FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=sqlite:///events.db
PORT=5050
USE_RELOADER=0

SCRAPE_SOURCE_MODE=priority
SCRAPE_TIMEOUT_SECONDS=15
SCRAPE_SOURCE_TIMEOUT_SECONDS=25
SCRAPE_RETRY_COUNT=1
SCRAPE_MAX_DETAIL_PAGES_PER_SOURCE=12
SCRAPE_MIN_QUALITY_SCORE=55
SCRAPE_INCLUDE_SAMPLE=0
SCRAPE_FOCUS_CATEGORIES=
SCRAPE_STATUS_RETENTION=12
CACHE_TTL_SECONDS=180

SCHEDULE_HOUR_UTC=1
