DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hk_events
BACKEND_CORS_ORIGINS=http://localhost:3000

# Optional: if you want the browser to call the API directly, define this in
# frontend/.env.local. Local dev now proxies same-origin /api requests to the
# backend automatically, so the repo-root .env file does not need it.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
